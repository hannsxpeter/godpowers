{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godpowers.dev/schema/state.v1.json",
  "title": "Godpowers Project State (v1)",
  "description": "Machine-managed project state. The 'facts' artifact in the three load-bearing artifacts pattern.",
  "type": "object",
  "required": ["$schema", "version", "project", "tiers"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://godpowers.dev/schema/state.v1.json"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "project": {
      "type": "object",
      "required": ["name", "started"],
      "properties": {
        "name": { "type": "string" },
        "started": { "type": "string", "format": "date-time" }
      }
    },
    "active-workstream": {
      "type": "string",
      "default": "main"
    },
    "tiers": {
      "type": "object",
      "patternProperties": {
        "^tier-[0-9]+$": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9-]*$": {
              "$ref": "#/$defs/SubStep"
            }
          }
        }
      }
    },
    "lifecycle-phase": {
      "type": "string",
      "enum": [
        "pre-init",
        "in-arc",
        "steady-state-active",
        "post-incident-pending",
        "in-migration",
        "spike-pending-followup"
      ]
    },
    "mode": {
      "type": "string",
      "enum": ["A", "B", "C", "E"],
      "description": "Mirror of intent.yaml mode for runtime queries. A=greenfield, B=brownfield/gap-fill, C=audit-only, E=bluefield."
    },
    "mode-d-suite": {
      "type": "boolean",
      "default": false,
      "description": "True when this repo is part of a multi-repo suite (god-coordinator owns suite scope)."
    },
    "mode-detected-from": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Signals used to detect the mode (e.g. 'no-package-json-found', 'org-context-yaml-in-parent')."
    },
    "mode-announced-as": {
      "type": "string",
      "description": "Human-friendly label shown to the user (greenfield/brownfield/bluefield/audit)."
    },
    "linkage": {
      "type": "object",
      "description": "Slot for linkage map summary. Authoritative file is .godpowers/linkage.json.",
      "additionalProperties": true
    },
    "deliverables": {
      "type": "object",
      "description": "Cached deliverable summary (requirement and roadmap-increment status). Recomputed fresh by lib/requirements.js from PRD + ROADMAP + linkage + build state; the human-readable ledger is .godpowers/REQUIREMENTS.mdx.",
      "additionalProperties": true,
      "properties": {
        "updated": { "type": "string" },
        "source": { "type": "string" },
        "requirements": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "done": { "type": "integer", "minimum": 0 },
            "in-progress": { "type": "integer", "minimum": 0 },
            "untouched": { "type": "integer", "minimum": 0 },
            "percent": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "increments": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "gaps": { "type": "integer", "minimum": 0 }
      }
    },
    "source-systems": {
      "type": "array",
      "description": "Detected external planning systems imported into Godpowers and eligible for managed sync-back. Includes the sibling superskill artifacts godplans (.godplans/PLAN.mdx) and godaudits (.godaudits/AUDIT.mdx).",
      "items": {
        "type": "object",
        "required": ["id", "name", "confidence", "files", "import-hash"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["legacy-planning", "bmad", "superpowers", "godplans", "godaudits", "other"]
          },
          "name": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "markers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "import-hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "imported-at": {
            "type": "string",
            "format": "date-time"
          },
          "sync-back-enabled": {
            "type": "boolean",
            "default": true
          },
          "last-sync-back-hash": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              { "type": "null" }
            ]
          },
          "last-sync-back-at": {
            "type": "string",
            "format": "date-time"
          },
          "conflict-count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "godpowers-features": {
      "type": "object",
      "description": "Installed Godpowers feature awareness recorded for this project.",
      "required": ["feature-set-version", "runtime-version", "known"],
      "properties": {
        "feature-set-version": {
          "type": "integer",
          "minimum": 1
        },
        "runtime-version": {
          "type": "string",
          "pattern": "^(unknown|\\d+\\.\\d+\\.\\d+)$"
        },
        "known": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last-awareness-refresh-at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "host-capabilities": {
      "type": "object",
      "description": "Most recent host guarantee report used by dashboard and release readiness surfaces.",
      "properties": {
        "host": { "type": "string" },
        "level": {
          "type": "string",
          "enum": ["full", "degraded", "unknown"]
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "checked-at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "dashboard": {
      "type": "object",
      "description": "Optional cached dashboard summary. Runtime recomputes from disk when present data is stale.",
      "properties": {
        "last-rendered-at": { "type": "string", "format": "date-time" },
        "action-brief": {
          "type": "object",
          "properties": {
            "next": { "type": "string" },
            "why": { "type": "string" },
            "readiness": { "type": "string", "enum": ["ready", "needs attention"] },
            "attention": { "type": "array", "items": { "type": "string" } },
            "host-guarantees": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dogfood": {
      "type": "object",
      "description": "Most recent deterministic messy-repo fixture run summary.",
      "properties": {
        "status": { "type": "string", "enum": ["not-run", "pass", "fail"] },
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "last-run-at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "yolo-decisions": {
      "type": "array",
      "description": "Auto-decisions made under --yolo. Mirrored to YOLO-DECISIONS.md.",
      "items": { "type": "object", "additionalProperties": true }
    },
    "lock": {
      "type": "object",
      "description": "Cooperative advisory lock for multi-user / multi-agent concurrency. The orchestrator acquires a lock before mutating state, releases on completion or after a stale-lock timeout. Concurrent writers see the lock and pause or pick a different sub-step.",
      "properties": {
        "holder": {
          "type": "string",
          "description": "Identifier of the actor holding the lock (e.g. 'alice@laptop', 'god-orchestrator@run-abc123')."
        },
        "acquired": {
          "type": "string",
          "format": "date-time"
        },
        "expires": {
          "type": "string",
          "format": "date-time",
          "description": "Lock auto-expires after this time. Stale locks (past expires) are reclaimable by any actor with a warning event."
        },
        "scope": {
          "type": "string",
          "description": "What the holder is currently mutating (e.g. 'tier-1.arch', 'linkage', 'all'). Lets concurrent actors pick non-conflicting work."
        }
      }
    }
  },
  "$defs": {
    "SubStep": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in-flight", "done", "skipped", "imported", "failed", "re-invoked", "not-required"]
        },
        "artifact": {
          "type": "string",
          "description": "Relative path from .godpowers/"
        },
        "artifact-hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "agent-version": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$"
        },
        "have-nots-passed": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{2}$"
          }
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Free-form for skip reason, failure detail, etc."
        },
        "readiness-scope": {
          "type": "string",
          "description": "Deploy, observe, or launch readiness scope such as local-readiness, local-staging, ci-readiness, deployed-staging, live-target, or deferred-external-access."
        },
        "verified-target-type": {
          "type": "string",
          "description": "Target class verified by deploy, observe, or launch work, such as local-staging, ci, deployed-staging, production, or live."
        },
        "target-evidence": {
          "type": "string",
          "description": "Evidence source for a deploy, observe, or launch target, such as config, CI variable, IaC output, provider CLI output, docs, or current user input."
        },
        "external-access-deferral": {
          "type": "string",
          "description": "Relative artifact path or concise reason when deployed staging, provider, dashboard, or live launch access is deferred."
        },
        "waiting-artifact": {
          "type": "string",
          "description": "Relative artifact path for the smallest outstanding external access bundle."
        },
        "rollback-evidence": {
          "type": "string",
          "description": "Deploy rollback command, run result, or artifact path proving rollback was tested."
        },
        "slo-evidence": {
          "type": "string",
          "description": "Observability evidence for SLO definitions and error budget policy coverage."
        },
        "alert-evidence": {
          "type": "string",
          "description": "Observability evidence for alert definitions and alert response coverage."
        },
        "runbook-evidence": {
          "type": "string",
          "description": "Observability or launch evidence for tested runbooks."
        },
        "launch-evidence": {
          "type": "string",
          "description": "Launch evidence for live launch, local launch-readiness, source attribution, or launch deferral."
        },
        "verification": {
          "type": "object",
          "description": "Structured verification evidence used by executable gates instead of markdown STATE.md parsing.",
          "properties": {
            "commands": {
              "type": "array",
              "items": { "$ref": "#/$defs/VerificationCommand" }
            }
          },
          "additionalProperties": true
        }
      }
    },
    "VerificationCommand": {
      "type": "object",
      "required": ["command", "status"],
      "properties": {
        "command": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pass", "passed", "green", "success", "succeeded", "ok", "fail", "failed", "red", "error", "skipped"]
        },
        "exitCode": { "type": "integer" },
        "ranAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "diagnostics": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
